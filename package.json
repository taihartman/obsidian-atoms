{
  "name": "obsidian-atoms",
  "version": "0.4.2",
  "description": "Classify past daily-note captures into atomic notes via Anthropic API",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "spike:api": "node scripts/spike-api.mjs",
    "seed:vault": "node scripts/seed-test-vault.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -noEmit -skipLibCheck"
  },
  "keywords": [
    "obsidian",
    "plugin"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.15.17",
    "esbuild": "0.25.5",
    "obsidian": "latest",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "obsidian-daily-notes-interface": "^0.9.4"
  }
}
