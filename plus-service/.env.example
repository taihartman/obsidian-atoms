# Copy to .env (not committed) and fill in.

ANTHROPIC_API_KEY=
PORT=8787
PUBLIC_BASE_URL=http://127.0.0.1:8787

# Dogfood: grant trial on first magic-link without Stripe
DOGFOOD_AUTO_GRANT=1
DOGFOOD_GRANT_STATUS=trialing

# Stripe test mode (from Dashboard → Developers → API keys)
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_
# From: node scripts/create-stripe-catalog.mjs
STRIPE_PRICE_MONTHLY=price_
STRIPE_PRICE_YEARLY=price_
STRIPE_PRICE_TOPUP=price_

# Force instant grants even when Stripe is configured (local only)
# STRIPE_DOGFOOD_CHECKOUT=1
